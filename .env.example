# Environment Configuration Template
# Copy this file to .env.development, .env.staging, or .env.production
# and fill in your actual values

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENV=development  # development | staging | production
DEBUG=true

# =============================================================================
# API CONFIGURATION
# =============================================================================
SECRET_KEY=change-this-to-a-random-secret-key-in-production
API_V1_STR=/api

# =============================================================================
# CORS ORIGINS
# =============================================================================
# Format: Comma-separated list of allowed origins (no spaces after commas)
# Development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production (add your Vercel domain)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-domain.com

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_DB=weather_bot
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=weather_pass

# Full database URL (used by FastAPI)
DATABASE_URL=postgresql://weather_user:weather_pass@postgres:5432/weather_bot

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=  # Leave empty for development, set in production
REDIS_OTP_TTL=600  # OTP expiry in seconds (10 minutes)
REDIS_WEATHER_CACHE_TTL=3600  # Weather cache in seconds (1 hour)

# =============================================================================
# TELEGRAM BOT
# =============================================================================
TELEGRAM_BOT_TOKEN=  # Get from @BotFather
TELEGRAM_WEBHOOK_URL=  # e.g., https://your-cloudflared-url.com/api/webhook/telegram

# =============================================================================
# OPENWEATHERMAP API
# =============================================================================
OPENWEATHER_API_KEY=  # Get from openweathermap.org
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# =============================================================================
# CELERY (if using instead of APScheduler)
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================
WEATHER_CHECK_INTERVAL=15  # Minutes between weather checks

# =============================================================================
# CLOUDFLARE TUNNEL (for external access)
# =============================================================================
CLOUDFLARE_TUNNEL_TOKEN=  # Get from Cloudflare dashboard

# =============================================================================
# FRONTEND (Vite)
# =============================================================================
VITE_API_URL=http://localhost:8000  # Backend API URL
